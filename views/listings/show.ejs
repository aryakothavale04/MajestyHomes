<%= layout("/layouts/boilerplate") %>

<script>
    let mapToken = "<%=process.env.MAP_TOKEN%>";
    let coordinates = <%- JSON.stringify(listing.geometry.coordinates) %>;
</script>
    <body>
        <div class="row">
            <div class="col-12 col-md-8 offset-md-2">
                <h3>
                    <%= listing.title %>
                </h3>
            </div>
            <div class="card col-12 col-md-8 offset-md-2 listing-card">
                <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing img">
                <div class="card-body">
                    <!-- <h5 class="card-title">
                        <%= listing.title %>
                    </h5> -->

                    <p class="card-text">
                        <%= listing.description %>
                    </p>
                    <p class="card-text">&#8377;<%= listing.price.toLocaleString("en-IN") %>
                    </p>
                    <p class="card-text">
                        <%= listing.country %>
                    </p>
                    <p class="card-text">
                        <%= listing.location %>
                    </p>
                    <p class="card-text">
                        Owner : <i>
                            <%= listing.owner.username %>
                        </i>
                    </p>
                    <% if (currUser && currUser._id.equals(listing.owner._id)){ %>

                        <div class="show-btn">
                            <a href="/listings/edit/<%=listing._id%>" class="btn btn-primary add-btn">Edit</a>
                            <form method="POST" action="/listings/delete/<%=listing._id%>?_method=DELETE">
                                <button class="btn btn-dark del-btn ">Delete</button>
                            </form>
                        </div>
                        <!-- add -->
                        <% } %>

                            <% if(currUser){ %>
                                <hr>
                                <div class="col-12 col-md-8"></div>
                                    <h4>Leave a Review</h4>
                                    <form action="/listings/<%=listing._id%>/reviews" method="POST"
                                        class="mb-3 needs-validation" novalidate>

                                        <div class="mt-3 mb-3">
                                            <label for="rating" class="form-range ">Rating:</label>
                                            <fieldset class="starability-slot">
                                                <input type="radio" id="no-rate" class="input-no-rate"
                                                    name="review[rating]" value="1" checked aria-label="No rating." />
                                                <input type="radio" id="second-rate1" name="review[rating]" value="1" />
                                                <label for="second-rate1" title="Terrible">1 star</label>
                                                <input type="radio" id="second-rate2" name="review[rating]" value="2" />
                                                <label for="second-rate2" title="Not good">2 stars</label>
                                                <input type="radio" id="second-rate3" name="review[rating]" value="3" />
                                                <label for="second-rate3" title="Average">3 stars</label>
                                                <input type="radio" id="second-rate4" name="review[rating]" value="4" />
                                                <label for="second-rate4" title="Very good">4 stars</label>
                                                <input type="radio" id="second-rate5" name="review[rating]" value="5" />
                                                <label for="second-rate5" title="Amazing">5 stars</label>
                                            </fieldset>
                                        </div>

                                        <div class="mt-3 mb-3">
                                            <label for="comment" class="form-label">Comment:</label>
                                            <textarea name="review[comment]" id="comment" cols="30" rows="5"
                                                class="form-control" required></textarea>
                                            <div class="invalid-feedback">Please add some comment for review</div>
                                        </div>
                                        <button class="btn btn-outline-dark mt-3">Submit</button>
                                    </form>
                                </div>


                                <% } %>
                                    <% if(listing.reviews.length>0 ) { %>

                                        <p><b>All Reviews</b></p>
                                        <% } %>
                                            <div class="row px-2 px-md-0">
                                                <% for (review of listing.reviews){ %>
                                                    <div class="card col-12 col-md-5 mb-3 mx-md-2">
                                                        <div class="card-body review-card">
                                                            <h5 class="card-title">@<%= review.author.username %>
                                                            </h5>
                                                            <p class="card-text">
                                                                <%= review.comment %>
                                                            </p>
                                                            <p class="starability-result"
                                                                data-rating="<%= review.rating %>">
                                                            </p>


                                                            <% if (currUser && currUser._id.equals(review.author._id)){
                                                                %>
                                                                <form method="POST"
                                                                    action="/listings/<%= listing._id %>/reviews/<%=review.id %>?_method=DELETE">
                                                                    <button
                                                                        class="btn btn-sm btn-dark mb-3">Delete</button>
                                                                </form>
                                                                <% } %>
                                                        </div>
                                                    </div>
                                                    <% } %>
                                            </div>
                </div>
                <hr>
            </div>
            <div class="card col-12 col-md-8 offset-md-2 listing-card">
                <h3>Where you’ll be</h3>
                <div id="map"></div>
            </div>
        </div>
        </div>

    <script src="/js/map.js"></script>
    </body>