<%= layout("/layouts/boilerplate") %>
    <style>
        #filters a {
            text-decoration: none;
            color: black;
        }

        #filters {
            display: flex;
            flex-direction: row;
            flex-wrap: wrap;
            margin-top: 1rem;
            align-items: center;
        }

        .filter {
            text-align: center;
            margin-right: 2rem;
            opacity: 0.7;
            margin-top: 0.5rem;
        }

        .filter:hover {
            opacity: 1;
            cursor: pointer;
        }

        .filter p {
            font-size: 0.8rem;
        }

        #tax-info {
            display: none;
        }

        .tax {
            border: 1px solid black;
            border-radius: 1rem;
            height: 2.5rem;
            padding: 0.5rem;
            margin-left: 12rem;
        }

        /* responsive filter  */
        @media (max-width: 768px) {

            #filters {
                flex-wrap: nowrap;
                overflow-x: auto;
                white-space: nowrap;
            }

            .tax {
                margin-left: 1rem;
            }
        } 
    </style>

    <body>
        <div class="filters" id="filters">

            <a href="/listings" class="filter">
                <div><i class="fa-solid fa-house"></i></div>
                <p>All Listings</p>
            </a>

            <a href="/listings?category=Rooms" class="filter">
                <div><i class="fa-solid fa-bed"></i></div>
                <p>Rooms</p>
            </a>

            <a href="/listings?category=Villas" class="filter">
                <div><i class="fa-solid fa-mountain-city"></i></div>
                <p>Villas</p>
            </a>

            <a href="/listings?category=Apartments" class="filter">
                <div><i class="fa-solid fa-building"></i></div>
                <p>Apartments</p>
            </a>

            <a href="/listings?category=Townhouses" class="filter">
                <div><i class="fa-solid fa-city"></i></div>
                <p>Townhouse</p>
            </a>

            <a href="/listings?category=Camps" class="filter">
                <div><i class="fa-solid fa-tent"></i></div>
                <p>Camps</p>
            </a>

            <a href="/listings?category=Historic" class="filter">
                <div><i class="fa-solid fa-archway"></i></div>
                <p>Historic</p>
            </a>

            <a href="/listings?category=Luxury" class="filter">
                <div><i class="fa-solid fa-gem"></i></div>
                <p>Luxurious</p>
            </a>

            <div class="tax">
                <div class="form-check form-switch form-check-reverse">
                    <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                    <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
                </div>
            </div>

        </div>




        <div class="row row-cols-2 row-cols-md-2 row-cols-lg-3 mt-3">
            <% for (let listing of allListings){ %>
                <div class="col">
                    <a href="/listings/<%= listing._id %>" class="listing-link">
                        <div class="card listing-card">
                            <div class="card-img-overlay"></div>
                            <img src="<%=listing.image.url%>" class="card-img-top" alt="listing_img">
                            <div class="card-body">
                                <p class="card-text">
                                    <b>
                                        <%=listing.title%><br>
                                    </b>
                                    &#8377;<%= listing.price.toLocaleString("en-IN") %>/night
                                        <i id="tax-info"> &nbsp; &nbsp; +18% GST</i>
                                </p>
                            </div>
                        </div>
                    </a>
                </div>
                <% } %>
        </div>
    </body>

    <script>
        let taxSwitch = document.getElementById("switchCheckDefault");
        taxSwitch.addEventListener("click", () => {
            let taxInfo = document.querySelectorAll("#tax-info");
            for (info of taxInfo) {
                if (info.style.display != "inline") {
                    info.style.display = "inline";
                } else {
                    info.style.display = "none";
                }

            }
        })

    </script>