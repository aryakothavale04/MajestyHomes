<% if (success?.length) { %>
<div class="alert alert-success mt-2 mb-2 alert-dismissible fade show col-12 col-md-6 offset-md-3 px-2 px-md-2" role="alert">
    <%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>

<% if (error?.length) { %>
<div class="alert alert-danger mt-2 mb-2 alert-dismissible fade show col-12 col-md-6 offset-md-3 px-2 px-md-2" role="alert">
    <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>